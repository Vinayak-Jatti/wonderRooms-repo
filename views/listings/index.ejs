<% layout("/layouts/boilerplate") %>

<section class="ribbon-wrapper">
  <div class="container d-flex align-items-center position-relative">
    <button class="scroll-btn scroll-left" id="scroll-left" aria-label="Scroll left">
      <i class="fa-solid fa-chevron-left"></i>
    </button>

    <div class="ribbon-container" id="ribbonContainer">
      <div class="ribbon-item active" data-category="trending">
        <i class="fa-solid fa-fire"></i><span>Trending</span>
      </div>
      <div class="ribbon-item" data-category="rooms">
        <i class="fa-solid fa-bed"></i><span>Rooms</span>
      </div>
      <div class="ribbon-item" data-category="cities">
        <i class="fa-solid fa-city"></i><span>Cities</span>
      </div>
      <div class="ribbon-item" data-category="mountains">
        <i class="fa-solid fa-mountain"></i><span>Mountains</span>
      </div>
      <div class="ribbon-item" data-category="castles">
        <i class="fa-solid fa-chess-rook"></i><span>Castles</span>
      </div>
      <div class="ribbon-item" data-category="pools">
        <i class="fa-solid fa-water-ladder"></i><span>Pools</span>
      </div>
      <div class="ribbon-item" data-category="camping">
        <i class="fa-solid fa-campground"></i><span>Camping</span>
      </div>
      <div class="ribbon-item" data-category="farms">
        <i class="fa-solid fa-tractor"></i><span>Farms</span>
      </div>
      <div class="ribbon-item" data-category="arctic">
        <i class="fa-solid fa-snowflake"></i><span>Arctic</span>
      </div>
      <div class="ribbon-item" data-category="domes">
        <i class="fa-solid fa-igloo"></i><span>Domes</span>
      </div>
      <div class="ribbon-item" data-category="boats">
        <i class="fa-solid fa-sailboat"></i><span>Boats</span>
      </div>
      <div class="ribbon-item" data-category="beach">
        <i class="fa-solid fa-umbrella-beach"></i><span>Beach</span>
      </div>
      <div class="ribbon-item" data-category="forest">
        <i class="fa-solid fa-tree"></i><span>Forest</span>
      </div>
      <div class="ribbon-item" data-category="hiking">
        <i class="fa-solid fa-person-hiking"></i><span>Hiking</span>
      </div>
      <div class="ribbon-item" data-category="skiing">
        <i class="fa-solid fa-person-skiing"></i><span>Skiing</span>
      </div>
      <div class="ribbon-item" data-category="hottubs">
        <i class="fa-solid fa-hot-tub-person"></i><span>Hot Tubs</span>
      </div>
      <div class="ribbon-item" data-category="fishing">
        <i class="fa-solid fa-fish"></i><span>Fishing</span>
      </div>
      <div class="ribbon-item" data-category="nightskies">
        <i class="fa-solid fa-moon"></i><span>Night Skies</span>
      </div>
      <div class="ribbon-item" data-category="nature">
        <i class="fa-solid fa-leaf"></i><span>Nature</span>
      </div>
      <div class="ribbon-item" data-category="modern">
        <i class="fa-solid fa-building"></i><span>Modern</span>
      </div>
      <div class="ribbon-item" data-category="party">
        <i class="fa-solid fa-champagne-glasses"></i><span>Party</span>
      </div>
    </div>

    <button class="scroll-btn scroll-right" id="scroll-right" aria-label="Scroll right">
      <i class="fa-solid fa-chevron-right"></i>
    </button>
  </div>
</section>

<div class="filter-bar">
  <div class="d-flex align-items-center gap-2">
    <% if (searchQuery) { %>
      <span class="search-result-badge">
        <i class="fa-solid fa-search me-1"></i>"<%= searchQuery %>" &middot; <%= totalListings %> result<%= totalListings !== 1 ? 's' : '' %>
      </span>
      <a href="/listings" class="btn btn-sm clear-search-btn">Clear</a>
    <% } else { %>
      <span class="text-muted small fw-semibold"><%= totalListings %> stays</span>
    <% } %>
  </div>
  <div class="d-flex align-items-center gap-2">
    <div class="switch-container">
      <span>Display total after taxes</span>
      <label class="switch">
        <input type="checkbox" id="taxSwitch" />
        <span class="slider"></span>
      </label>
    </div>
    <button class="filter-btn">
      <i class="fa-solid fa-sliders"></i> Filter
    </button>
  </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4" id="listings">
  <% if(allListings && allListings.length > 0) { %>
    <% for (let listing of allListings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card listing" data-price="<%= listing.price || 0 %>">
          <div class="card-img-wrapper">
            <img
              src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1549294413-26f195200c16?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>"
              class="card-img-top blur-up"
              alt="<%= listing.title %>"
              loading="lazy"
              onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1549294413-26f195200c16?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80';"
            />
          </div>
          <button
            class="heart-btn"
            data-id="<%= listing._id %>"
            aria-label="Save listing"
            onclick="event.preventDefault();event.stopPropagation();"
          >
            <i class="fa-heart"></i>
          </button>
          <div class="card-body">
            <p class="card-text mb-0">
              <b class="listing-title"><%= listing.title %></b>
              <br />
              <span class="text-muted small">
                <i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %>
              </span>
              <br />
              <span class="price fw-bold mt-1 d-inline-block">&#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></span>
              <span class="text-muted small"> / night</span>
            </p>
          </div>
        </div>
      </a>
    </div>
    <% } %>
  <% } else { %>
    <div class="col-12 mt-5 text-center empty-state w-100">
      <div class="empty-state-icon">
        <i class="fa-solid fa-magnifying-glass-location"></i>
      </div>
      <h3 class="fw-bold mt-3">No destinations found!</h3>
      <p class="text-muted">
        We couldn't find anything matching your search.
        <br />
        <a href="/listings" class="btn btn-outline-danger btn-sm mt-3 fw-bold">Explore All Rooms</a>
      </p>
    </div>
  <% } %>
</div>

<% if (totalPages > 1) { %>
<nav class="pagination-wrapper" aria-label="Listings pagination">
  <ul class="clay-pagination">
    <% if (currentPage > 1) { %>
      <li>
        <a href="/listings?page=<%= currentPage - 1 %><%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="clay-page-btn">
          <i class="fa-solid fa-chevron-left"></i>
        </a>
      </li>
    <% } %>

    <% for (let p = 1; p <= totalPages; p++) { %>
      <% if (p === 1 || p === totalPages || (p >= currentPage - 1 && p <= currentPage + 1)) { %>
        <li>
          <a
            href="/listings?page=<%= p %><%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>"
            class="clay-page-btn <%= p === currentPage ? 'active' : '' %>"
          >
            <%= p %>
          </a>
        </li>
      <% } else if (p === currentPage - 2 || p === currentPage + 2) { %>
        <li><span class="clay-page-dots">&hellip;</span></li>
      <% } %>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <li>
        <a href="/listings?page=<%= currentPage + 1 %><%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" class="clay-page-btn">
          <i class="fa-solid fa-chevron-right"></i>
        </a>
      </li>
    <% } %>
  </ul>
</nav>
<% } %>
