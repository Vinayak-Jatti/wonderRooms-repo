<% layout("/layouts/boilerplate") %>

<section class="clay-form-page">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-7">
      <div class="clay-card">
        <div class="clay-card-header">
          <h3 class="clay-card-title">
            <i class="fa-solid fa-circle-plus me-2"></i>Create New Listing
          </h3>
          <p class="text-muted mb-0 small">Fill in the details to list your space</p>
        </div>

        <form
          action="/listings"
          method="post"
          class="needs-validation"
          enctype="multipart/form-data"
          novalidate
        >
          <div class="clay-form-group">
            <label for="title" class="clay-label">
              Title <span class="text-danger">*</span>
            </label>
            <input
              type="text"
              class="form-control clay-input"
              id="title"
              name="listing[title]"
              placeholder="e.g. Cozy Mountain Cabin"
              required
            />
            <div class="invalid-feedback">Please enter a title.</div>
          </div>

          <div class="clay-form-group">
            <label for="description" class="clay-label">Description</label>
            <textarea
              name="listing[description]"
              id="description"
              rows="4"
              placeholder="Describe your space, amenities, and what makes it special..."
              class="form-control clay-input"
              required
            ></textarea>
            <div class="invalid-feedback">Please enter a description.</div>
          </div>

          <div class="clay-form-group">
            <label for="imageUrl" class="clay-label">
              <i class="fa-solid fa-cloud-arrow-up me-1"></i>Upload Listing Image
            </label>
            <input
              type="file"
              class="form-control clay-input"
              id="imageUrl"
              name="listing[image]"
              accept="image/*"
            />
          </div>

          <div class="row g-3">
            <div class="col-md-4">
              <div class="clay-form-group">
                <label for="price" class="clay-label">
                  Price (₹/night) <span class="text-danger">*</span>
                </label>
                <input
                  type="number"
                  class="form-control clay-input"
                  id="price"
                  name="listing[price]"
                  placeholder="2500"
                  min="1"
                  required
                />
                <div class="invalid-feedback">Please enter a price.</div>
              </div>
            </div>
            <div class="col-md-8">
              <div class="clay-form-group">
                <label for="country" class="clay-label">Country <span class="text-danger">*</span></label>
                <input
                  type="text"
                  class="form-control clay-input"
                  id="country"
                  name="listing[country]"
                  placeholder="e.g. India"
                  required
                />
                <div class="invalid-feedback">Please enter a country.</div>
              </div>
            </div>
          </div>

          <div class="clay-form-group">
            <label for="location" class="clay-label">
              <i class="fa-solid fa-location-dot me-1"></i>Location <span class="text-danger">*</span>
            </label>
            <input
              type="text"
              class="form-control clay-input"
              id="location"
              name="listing[location]"
              placeholder="e.g. Manali, Himachal Pradesh"
              required
            />
            <div class="invalid-feedback">Please enter a location.</div>
          </div>

          <button type="submit" class="btn btn-primary clay-submit-btn w-100">
            <i class="fa-solid fa-plus me-2"></i>Add to Listings
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
