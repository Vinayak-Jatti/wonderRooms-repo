<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center py-5">
  <div class="col-12 col-md-10 col-lg-7">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4 p-md-5">
        <div class="mb-5">
          <h2 class="fw-bold text-dark mb-2">List your space</h2>
          <p class="text-muted">Fill out the details below to help students find your room.</p>
        </div>

        <form action="/listings" method="POST" class="needs-validation" enctype="multipart/form-data" novalidate>
          <div class="mb-4">
            <label for="title" class="form-label fw-bold small text-uppercase">Title</label>
            <input type="text" class="form-control form-control-lg" id="title" name="listing[title]" placeholder="e.g. Spacious 1BHK near University" required />
            <div class="invalid-feedback">Please enter a title.</div>
          </div>

          <div class="mb-4">
            <label for="description" class="form-label fw-bold small text-uppercase">Description</label>
            <textarea name="listing[description]" id="description" rows="5" class="form-control" placeholder="Tell students about the room, amenities, and nearby landmarks..." required></textarea>
            <div class="invalid-feedback">Please enter a description.</div>
          </div>

          <div class="mb-4">
            <label for="image" class="form-label fw-bold small text-uppercase">Upload Image</label>
            <input type="file" class="form-control" id="image" name="listing[image]" accept="image/*" />
            <div class="form-text">Choose a high-quality photo to attract more attention.</div>
          </div>

          <div class="row g-4 mb-4">
            <div class="col-md-6">
              <label for="price" class="form-label fw-bold small text-uppercase">Price (₹/month)</label>
              <div class="input-group">
                <span class="input-group-text bg-white border-end-0">₹</span>
                <input type="number" class="form-control border-start-0 ps-0" id="price" name="listing[price]" placeholder="12000" min="0" required />
                <div class="invalid-feedback">Please enter a valid price.</div>
              </div>
            </div>
            <div class="col-md-6">
              <label for="country" class="form-label fw-bold small text-uppercase">Country</label>
              <input type="text" class="form-control" id="country" name="listing[country]" placeholder="e.g. India" required />
              <div class="invalid-feedback">Please enter a country.</div>
            </div>
          </div>

          <div class="mb-5">
            <label for="location" class="form-label fw-bold small text-uppercase">Location</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-location-dot text-primary"></i></span>
              <input type="text" class="form-control border-start-0 ps-0" id="location" name="listing[location]" placeholder="e.g. Indiranagar, Bangalore" required />
              <div class="invalid-feedback">Please enter a location.</div>
            </div>
          </div>

          <div class="d-grid gap-3 pt-3">
            <button type="submit" class="btn btn-primary btn-lg fw-bold py-3 rounded-3">
              Proceed to List
            </button>
            <a href="/listings" class="btn btn-outline-dark btn-lg py-3 rounded-3 fw-semibold">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
