<% layout("/layouts/boilerplate") %>

<div class="row justify-content-center py-5">
  <div class="col-12 col-md-10 col-lg-7">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4 p-md-5">
        <div class="mb-5">
          <h2 class="fw-bold text-dark mb-2">Edit your listing</h2>
          <p class="text-muted">Update the details of your space to keep students informed.</p>
        </div>

        <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" class="needs-validation" enctype="multipart/form-data" novalidate>
          <div class="mb-4">
            <label for="title" class="form-label fw-bold small text-uppercase">Title</label>
            <input type="text" class="form-control form-control-lg" id="title" name="listing[title]" value="<%= listing.title %>" required />
            <div class="invalid-feedback">Please enter a title.</div>
          </div>

          <div class="mb-4">
            <label for="description" class="form-label fw-bold small text-uppercase">Description</label>
            <textarea name="listing[description]" id="description" rows="5" class="form-control" required><%= listing.description %></textarea>
            <div class="invalid-feedback">Please enter a description.</div>
          </div>

          <div class="d-flex align-items-start gap-4 mb-4">
            <% if (ogUrl) { %>
              <div class="current-img-preview">
                <p class="small fw-bold text-uppercase text-muted mb-2">Current Image</p>
                <img src="<%= ogUrl %>" class="rounded-3" style="width: 120px; aspect-ratio: 1; object-fit: cover; border: 1px solid var(--border-light);" />
              </div>
            <% } %>
            <div class="flex-grow-1">
              <label for="image" class="form-label fw-bold small text-uppercase">Upload New Image</label>
              <input type="file" class="form-control" id="image" name="listing[image]" accept="image/*" />
            </div>
          </div>

          <div class="row g-4 mb-4">
            <div class="col-md-6">
              <label for="price" class="form-label fw-bold small text-uppercase">Price (₹/month)</label>
              <div class="input-group">
                <span class="input-group-text bg-white border-end-0">₹</span>
                <input type="number" class="form-control border-start-0 ps-0" id="price" name="listing[price]" value="<%= listing.price %>" min="0" required />
              </div>
            </div>
            <div class="col-md-6">
              <label for="country" class="form-label fw-bold small text-uppercase">Country</label>
              <input type="text" class="form-control" id="country" name="listing[country]" value="<%= listing.country %>" required />
            </div>
          </div>

          <div class="mb-5">
            <label for="location" class="form-label fw-bold small text-uppercase">Location</label>
            <div class="input-group">
              <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-location-dot text-primary"></i></span>
              <input type="text" class="form-control border-start-0 ps-0" id="location" name="listing[location]" value="<%= listing.location %>" required />
            </div>
          </div>

          <div class="d-grid gap-3 pt-3">
            <button type="submit" class="btn btn-primary btn-lg fw-bold py-3 rounded-3 shadow-sm">
              Save Changes
            </button>
            <a href="/listings/<%= listing._id %>" class="btn btn-outline-dark btn-lg py-3 rounded-3 fw-semibold">Discard Changes</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
