<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2">
    <div class="card shadow-sm border-0 mb-4 rounded-4 overflow-hidden">
      <div class="p-3">
        <h3 class="mb-0 fw-bold text-dark"><%= listing.title %></h3>
      </div>
      <img
        src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1549294413-26f195200c16?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>"
        alt="Listing Image"
        class="card-img-top img-fluid w-100"
        style="max-height: 500px; object-fit: cover;"
        onerror="this.onerror=null;this.src='https://images.unsplash.com/photo-1549294413-26f195200c16?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80';"
      />
      <div class="card-body p-4">
    <p class="text-muted d-flex align-items-center mb-3">
      <i class="fa-solid fa-user-circle fs-4 me-2 text-primary"></i>
      <span>Owned by: <span class="fw-bold text-dark"><%= listing.owner ? listing.owner.username : "Unknown" %></span></span>
    </p>
    <p class="card-text"><%= listing.description %></p>
    <p class="card-text">
      <strong>Price:</strong>
      &#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A"
      %>/night
    </p>
    <p class="card-text">
      <strong>Location:</strong> <%= listing.location %>, <%= listing.country %>
    </p>
  </div>

  <% if (currUser && listing.owner && currUser._id.toString() ===
  listing.owner._id.toString()) { %>
  <div class="btn-container my-4 d-flex gap-2">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark px-4 fw-semibold rounded-3 shadow-sm"
      >Edit <i class="fa-solid fa-pen-to-square ms-1"></i></a
    >
    <form
      method="POST"
      action="/listings/<%= listing._id %>?_method=DELETE"
      class="d-inline"
    >
      <button
        type="submit"
        class="btn btn-danger px-4 fw-semibold rounded-3 shadow-sm"
        onclick="return confirm('Are you sure you want to delete this listing?');"
      >
        Delete <i class="fa-solid fa-trash ms-1"></i>
      </button>
    </form>
  </div>
  <% } %> 
  </div> <!-- Close card-body -->
  </div> <!-- Close card -->  <!-- Leave a Review -->
  <% if(currUser) { %>
  <div class="card shadow-sm border-0 mb-4 rounded-4">
    <div class="card-body p-4">
      <h4 class="mb-4 fw-bold"><i class="fa-solid fa-pen-nib me-2 text-primary"></i>Leave a Review</h4>
      <form
        action="/listings/<%= listing._id %>/reviews"
        method="POST"
        novalidate
        class="needs-validation"
      >
        <div class="mb-4">
          <label for="rating" class="form-label fw-semibold">Rating</label>
          <input
            type="range"
            class="form-range"
            min="1"
            max="5"
            id="rating"
            name="review[rating]"
          />
          <div class="d-flex justify-content-between small text-muted font-monospace">
            <span>1 ⭐</span>
            <span>2 ⭐</span>
            <span>3 ⭐</span>
            <span>4 ⭐</span>
            <span>5 ⭐</span>
          </div>
        </div>

        <div class="mb-4">
          <label for="comment" class="form-label fw-semibold">Comments</label>
          <textarea
            class="form-control rounded-3 bg-light border-0"
            name="review[comment]"
            id="comment"
            rows="4"
            placeholder="Share your experience..."
            required
          ></textarea>
          <div class="invalid-feedback">Please submit a valid comment.</div>
        </div>

        <button type="submit" class="btn btn-primary fw-bold px-4 py-2 rounded-3 shadow-sm">Submit Review <i class="fa-solid fa-paper-plane ms-1"></i></button>
      </form>
    </div>
  </div>
  <% } %>

  <!-- Show Reviews -->
  <div class="card shadow-sm border-0 rounded-4 mb-5">
    <div class="card-body p-4">
      <h4 class="mb-4 fw-bold"><i class="fa-solid fa-star-half-stroke me-2 text-warning"></i>Reviews</h4>
      <% if (listing.reviews && listing.reviews.length > 0) { %>
      <div class="row row-cols-1 row-cols-md-2 g-4">
        <% listing.reviews.forEach(review => { %>
        <div class="col">
          <div class="card h-100 border border-light bg-light rounded-4 shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0 fw-bold d-flex align-items-center"><i class="fa-solid fa-circle-user fs-4 me-2 text-secondary"></i>@<%= review.author.username %></h6>
                <span class="badge bg-warning text-dark border"><i class="fa-solid fa-star me-1"></i><%= review.rating %></span>
              </div>
              <p class="card-text text-muted mb-3"><%= review.comment %></p>
              
              <% if (currUser && currUser._id.toString() === review.author._id.toString()) { %>
              <form
                method="POST"
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                class="text-end"
              >
                <button class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm">Delete</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="text-center py-4">
        <i class="fa-solid fa-comments fs-1 text-muted opacity-50 mb-3"></i>
        <p class="text-muted mb-0 fs-5">No reviews yet.</p>
        <p class="text-muted small">Be the first to share your experience!</p>
      </div>
      <% } %>
    </div>
  </div>
  
  </div> <!-- Close outer col wrapper -->
</div>
