<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2">
    <div class="card show-card border-0 shadow-sm rounded-5 overflow-hidden">
      <div class="card-header bg-white border-0 py-4 px-4">
        <h2 class="mb-1 fw-bold text-dark"><%= listing.title %></h2>
        <div class="text-muted d-flex align-items-center gap-2">
          <i class="fa-solid fa-location-dot text-primary"></i>
          <span><%= listing.location %>, <%= listing.country %></span>
        </div>
      </div>
      
      <div class="show-img-container px-4">
        <img
          src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1549294413-26f195200c16?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>"
          alt="<%= listing.title %>"
          class="img-fluid w-100 rounded-4 shadow-sm"
          style="height: 450px; object-fit: cover;"
        />
      </div>

      <div class="card-body p-4 p-md-5">
        <div class="row">
          <div class="col-md-8">
            <h4 class="fw-bold mb-3">About this space</h4>
            <p class="card-text text-muted lh-lg"><%= listing.description %></p>
            
            <div class="host-info d-flex align-items-center gap-3 p-3 bg-light rounded-4 mt-4">
              <i class="fa-solid fa-circle-user fs-1 text-primary"></i>
              <div>
                <span class="text-muted small d-block">Hosted by</span>
                <span class="fw-bold text-dark fs-5"><%= listing.owner ? listing.owner.username : "Verified Host" %></span>
              </div>
            </div>
          </div>
          
          <div class="col-md-4 mt-4 mt-md-0">
            <div class="sticky-top" style="top: 100px;">
              <div class="card border border-light rounded-4 shadow-sm p-4">
                <div class="mb-3">
                  <span class="fs-3 fw-bold">&#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></span>
                  <span class="text-muted"> / night</span>
                </div>
                <div class="d-grid gap-2">
                  <button class="btn btn-primary btn-lg fw-bold rounded-3 py-3">Reserve Now</button>
                  <p class="text-center text-muted small mt-2">You won't be charged yet</p>
                </div>
              </div>

              <% if (locals.currUser && listing.owner && locals.currUser._id.toString() === listing.owner._id.toString()) { %>
              <div class="d-flex gap-2 mt-3">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark flex-fill fw-bold rounded-3">Edit</a>
                <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="flex-fill">
                  <button type="submit" class="btn btn-outline-danger w-100 fw-bold rounded-3" onclick="return confirm('Confirm deletion?');">Delete</button>
                </form>
              </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>  <!-- Leave a Review -->
  <% if(locals.currUser) { %>
  <div class="card shadow-sm border-0 mb-4 rounded-4">
    <div class="card-body p-4">
      <h4 class="mb-4 fw-bold"><i class="fa-solid fa-pen-nib me-2 text-primary"></i>Leave a Review</h4>
      <form
        action="/listings/<%= listing._id %>/reviews"
        method="POST"
        novalidate
        class="needs-validation"
      >
        <div class="mb-4">
          <label for="rating" class="form-label fw-semibold">Rating</label>
          <input
            type="range"
            class="form-range"
            min="1"
            max="5"
            id="rating"
            name="review[rating]"
          />
          <div class="d-flex justify-content-between small text-muted font-monospace">
            <span>1 ⭐</span>
            <span>2 ⭐</span>
            <span>3 ⭐</span>
            <span>4 ⭐</span>
            <span>5 ⭐</span>
          </div>
        </div>

        <div class="mb-4">
          <label for="comment" class="form-label fw-semibold">Comments</label>
          <textarea
            class="form-control rounded-3 bg-light border-0"
            name="review[comment]"
            id="comment"
            rows="4"
            placeholder="Share your experience..."
            required
          ></textarea>
          <div class="invalid-feedback">Please submit a valid comment.</div>
        </div>

        <button type="submit" class="btn btn-primary fw-bold px-4 py-2 rounded-3 shadow-sm">Submit Review <i class="fa-solid fa-paper-plane ms-1"></i></button>
      </form>
    </div>
  </div>
  <% } %>

  <!-- Show Reviews -->
  <div class="card shadow-sm border-0 rounded-4 mb-5">
    <div class="card-body p-4">
      <h4 class="mb-4 fw-bold"><i class="fa-solid fa-star-half-stroke me-2 text-warning"></i>Reviews</h4>
      <% if (listing.reviews && listing.reviews.length > 0) { %>
      <div class="row row-cols-1 row-cols-md-2 g-4">
        <% listing.reviews.forEach(review => { %>
        <div class="col">
          <div class="card h-100 border border-light bg-light rounded-4 shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0 fw-bold d-flex align-items-center"><i class="fa-solid fa-circle-user fs-4 me-2 text-secondary"></i>@<%= review.author.username %></h6>
                <span class="badge bg-warning text-dark border"><i class="fa-solid fa-star me-1"></i><%= review.rating %></span>
              </div>
              <p class="card-text text-muted mb-3"><%= review.comment %></p>
              
              <% if (locals.currUser && locals.currUser._id.toString() === review.author._id.toString()) { %>
              <form
                method="POST"
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                class="text-end"
              >
                <button class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm">Delete</button>
              </form>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="text-center py-4">
        <i class="fa-solid fa-comments fs-1 text-muted opacity-50 mb-3"></i>
        <p class="text-muted mb-0 fs-5">No reviews yet.</p>
        <p class="text-muted small">Be the first to share your experience!</p>
      </div>
      <% } %>
    </div>
  </div>
  
  </div> <!-- Close outer col wrapper -->
</div>
