<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="WonderRooms — Discover unique stays, from cozy cabins to luxury villas. Book your next adventure today." />
    <title>WonderRooms — Discover Unique Stays</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css"
    />
    <style>
      :root {
        --primary: #e51d53;
        --bg: #e8e4df;
        --surface: #eae6e1;
        --text: #2d2a26;
        --text-muted: #7a7572;
        --clay-outer: 6px 6px 12px rgba(0,0,0,0.12), -4px -4px 10px rgba(255,255,255,0.7);
        --clay-inner: inset 2px 2px 4px rgba(255,255,255,0.6), inset -1px -1px 3px rgba(0,0,0,0.05);
        --clay-hover: 10px 10px 24px rgba(0,0,0,0.16), -6px -6px 16px rgba(255,255,255,0.8);
        --clay-pressed: inset 4px 4px 8px rgba(0,0,0,0.12), inset -2px -2px 6px rgba(255,255,255,0.5);
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: "Plus Jakarta Sans", sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        overflow-x: hidden;
      }

      a { text-decoration: none; color: inherit; }

      .landing-hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 2rem;
        position: relative;
      }

      .hero-badge {
        background: var(--surface);
        box-shadow: var(--clay-outer), var(--clay-inner);
        border-radius: 50px;
        padding: 0.4rem 1.2rem;
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 2rem;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        animation: fadeInUp 0.5s ease both;
      }

      .hero-title {
        font-size: clamp(2.2rem, 6vw, 4.5rem);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.2rem;
        animation: fadeInUp 0.5s ease 0.1s both;
        max-width: 700px;
      }

      .hero-title span {
        color: var(--primary);
      }

      .hero-subtitle {
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: var(--text-muted);
        margin-bottom: 2.5rem;
        max-width: 520px;
        line-height: 1.6;
        font-weight: 500;
        animation: fadeInUp 0.5s ease 0.2s both;
      }

      .hero-cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: center;
        animation: fadeInUp 0.5s ease 0.3s both;
      }

      .btn-clay-primary {
        background: var(--primary);
        color: white;
        border: none;
        padding: 0.8rem 2rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1rem;
        box-shadow: 4px 4px 12px rgba(229,29,83,0.3),
                    inset 1px 1px 2px rgba(255,255,255,0.15);
        transition: all 0.25s ease;
        cursor: pointer;
      }

      .btn-clay-primary:hover {
        transform: translateY(-3px);
        box-shadow: 6px 6px 18px rgba(229,29,83,0.4),
                    inset 1px 1px 2px rgba(255,255,255,0.15);
        color: white;
      }

      .btn-clay-primary:active {
        transform: translateY(0);
        box-shadow: var(--clay-pressed);
      }

      .btn-clay-secondary {
        background: var(--surface);
        color: var(--text);
        border: none;
        padding: 0.8rem 2rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1rem;
        box-shadow: var(--clay-outer), var(--clay-inner);
        transition: all 0.25s ease;
        cursor: pointer;
      }

      .btn-clay-secondary:hover {
        transform: translateY(-3px);
        box-shadow: var(--clay-hover);
        color: var(--primary);
      }

      .btn-clay-secondary:active {
        box-shadow: var(--clay-pressed);
        transform: translateY(0);
      }

      /* Feature Cards */
      .features-section {
        padding: 4rem 2rem;
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        max-width: 1000px;
        margin: 0 auto;
      }

      .feature-card {
        background: var(--surface);
        box-shadow: var(--clay-outer), var(--clay-inner);
        border-radius: 20px;
        padding: 2rem 1.5rem;
        text-align: center;
        width: 280px;
        transition: all 0.3s ease;
      }

      .feature-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--clay-hover), var(--clay-inner);
      }

      .feature-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--bg);
        box-shadow: var(--clay-outer), var(--clay-inner);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: var(--primary);
        margin-bottom: 1rem;
      }

      .feature-card h4 {
        font-weight: 700;
        font-size: 1.05rem;
        margin-bottom: 0.5rem;
      }

      .feature-card p {
        color: var(--text-muted);
        font-size: 0.88rem;
        line-height: 1.5;
        margin: 0;
      }

      /* Stats */
      .stats-row {
        display: flex;
        justify-content: center;
        gap: 3rem;
        padding: 2rem;
        margin-bottom: 3rem;
        animation: fadeInUp 0.5s ease 0.4s both;
        flex-wrap: wrap;
      }

      .stat-item {
        text-align: center;
      }

      .stat-number {
        font-size: 2rem;
        font-weight: 800;
        color: var(--primary);
      }

      .stat-label {
        font-size: 0.82rem;
        color: var(--text-muted);
        font-weight: 600;
      }

      /* Footer */
      .landing-footer {
        text-align: center;
        padding: 2rem;
        color: var(--text-muted);
        font-size: 0.85rem;
        font-weight: 600;
      }

      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @media (max-width: 576px) {
        .features-section {
          padding: 2rem 1rem;
        }

        .feature-card {
          width: 100%;
        }

        .stats-row {
          gap: 1.5rem;
        }

        .hero-cta {
          flex-direction: column;
          align-items: center;
        }
      }
    </style>
  </head>
  <body>
    <section class="landing-hero">
      <div class="hero-badge">
        <i class="fa-solid fa-sparkles"></i> Trusted by 1000+ travelers
      </div>

      <h1 class="hero-title">
        Find Your <span>Wonder</span>ful Stay
      </h1>

      <p class="hero-subtitle">
        From cozy mountain cabins to luxury beachfront villas — discover unique spaces to stay, experience, and remember forever.
      </p>

      <div class="hero-cta">
        <a href="/listings" class="btn-clay-primary">
          <i class="fa-solid fa-compass me-2"></i>Explore Stays
        </a>
        <a href="/signup" class="btn-clay-secondary">
          <i class="fa-solid fa-user-plus me-2"></i>Join Free
        </a>
      </div>

      <div class="stats-row">
        <div class="stat-item">
          <div class="stat-number">500+</div>
          <div class="stat-label">Unique Stays</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">50+</div>
          <div class="stat-label">Countries</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">4.8</div>
          <div class="stat-label">Avg Rating</div>
        </div>
      </div>
    </section>

    <section class="features-section">
      <div class="feature-card">
        <div class="feature-icon">
          <i class="fa-solid fa-shield-halved"></i>
        </div>
        <h4>Verified Hosts</h4>
        <p>Every host is verified for your safety and peace of mind.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <i class="fa-solid fa-bolt"></i>
        </div>
        <h4>Instant Booking</h4>
        <p>Book your stay in seconds with our streamlined experience.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon">
          <i class="fa-solid fa-globe"></i>
        </div>
        <h4>Global Reach</h4>
        <p>Stays across 50+ countries from mountains to beaches.</p>
      </div>
    </section>

    <footer class="landing-footer">
      &copy; <%= new Date().getFullYear() %> WonderRooms Private Limited
    </footer>
  </body>
</html>
